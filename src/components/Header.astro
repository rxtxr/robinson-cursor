---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav aria-label="Main navigation">
    <a href="/" class="logo" aria-label="robinson-cursor — home">
      <span class="logo-prompt" aria-hidden="true">&gt;</span>robinson-cursor<span class="logo-cursor" aria-hidden="true">_</span>
    </a>
    <ul class="nav-links">
      <li><a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>projects</a></li>
      <li><a href="/about" aria-current={currentPath === '/about' || currentPath === '/about/' ? 'page' : undefined}>about</a></li>
      <li><a href="/rss.xml" aria-label="RSS feed">rss</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .logo:hover { color: var(--color-accent); }

  .logo-prompt {
    color: var(--color-accent);
    opacity: 0.6;
  }

  .logo-cursor {
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .nav-links a:hover,
  .nav-links a[aria-current="page"] {
    color: var(--color-accent);
  }
</style>
