---
import { getProjectCount } from '../lib/projects.js';

const projectCount = await getProjectCount();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-meta">
      <span class="project-counter">{projectCount} / 365 projekte</span>
      <span class="separator">&middot;</span>
      <a href="https://github.com/rxtxr/robinson-cursor" target="_blank" rel="noopener">github</a>
      <span class="separator">&middot;</span>
      <span>&copy; {year}</span>
    </div>

    <div class="imprint">
      <p class="imprint-title">Impressum — Angaben gemäß § 5 TMG</p>
      <p>[Name] &middot; [Adresse] &middot; [E-Mail]</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) var(--space-md);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .project-counter {
    color: var(--color-accent-dim);
  }

  .separator {
    color: var(--color-border);
  }

  .imprint {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .imprint-title {
    font-weight: 600;
    color: var(--color-text);
  }
</style>
