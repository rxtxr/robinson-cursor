---
import { getProjectCount } from '../lib/projects.js';

const projectCount = await getProjectCount();
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <nav class="footer-inner" aria-label="Footer navigation">
    <div class="footer-meta">
      <span class="project-counter">{projectCount} / 365 projects</span>
      <span class="separator" aria-hidden="true">&middot;</span>
      <a href="https://github.com/rxtxr/robinson-cursor" target="_blank" rel="noopener" aria-label="Source code on GitHub (opens in new tab)">github</a>
      <span class="separator" aria-hidden="true">&middot;</span>
      <a href="/imprint" rel="nofollow">imprint</a>
      <span class="separator" aria-hidden="true">&middot;</span>
      <a href="/privacy">privacy</a>
      <span class="separator" aria-hidden="true">&middot;</span>
      <a href="/bug-bounty">bug bounty</a>
      <span class="separator" aria-hidden="true">&middot;</span>
      <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener" aria-label="MIT License (opens in new tab)">MIT</a>
      <span class="separator" aria-hidden="true">&middot;</span>
      <span>&copy; {year}</span>
    </div>
  </nav>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) var(--space-md);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .project-counter {
    color: var(--color-accent-dim);
  }

  .separator {
    color: var(--color-border);
  }
</style>
