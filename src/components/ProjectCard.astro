---
const { project, thumbUrl, thumbWebp } = Astro.props;
const dayNum = String(project.day).padStart(3, '0');
const isTemplate = project.status === 'template';
const isWip = project.status === 'wip';
const isIncomplete = project.status === 'incomplete';
const isFail = project.status === 'fail';
const statusBadge = isWip ? (project.statusLabel || 'work in progress') : isIncomplete ? 'incomplete' : isFail ? 'fail' : null;
---

<a href={`/projects/${project.slug}`} class:list={['project-card', { 'card-template': isTemplate, 'card-wip': isWip, 'card-incomplete': isIncomplete, 'card-fail': isFail }]} style={project.accentColor ? `--color-accent: ${project.accentColor}` : ''} aria-label={`Day ${dayNum}: ${project.title}`}>
  {thumbUrl ? (
    <div class="card-thumb">
      <picture>
        {thumbWebp && <source srcset={thumbWebp} type="image/webp" />}
        <img src={thumbUrl} alt="" loading="lazy" />
      </picture>
    </div>
  ) : (
    <div class="card-thumb card-thumb-empty" aria-hidden="true">
      <span class="thumb-placeholder">#{dayNum}</span>
    </div>
  )}
  <div class="card-body">
    <div class="card-header">
      <span class="day-number" aria-hidden="true">#{dayNum}</span>
      <time class="date" datetime={project.date}>{project.date}</time>
    </div>
    <h3 class="card-title">
      {statusBadge && <span class:list={['status-badge', { 'badge-wip': isWip, 'badge-incomplete': isIncomplete, 'badge-fail': isFail }]}>{statusBadge}</span>}
      {project.title}
    </h3>
    <p class="card-description">{project.description}</p>
    <div class="card-tags">
      {project.tags.map((tag) => (
        <span class="badge">{tag}</span>
      ))}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: background 0.2s, border-color 0.2s;
    text-decoration: none;
    overflow: hidden;
  }

  .project-card:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
  }

  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-thumb-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
  }

  .thumb-placeholder {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-border);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .day-number {
    color: var(--color-accent);
    font-weight: 700;
  }

  .date {
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: 1.1rem;
    color: var(--color-text-heading);
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .card-wip {
    border-color: #c0392b;
  }

  .card-wip:hover {
    border-color: #e74c3c;
  }

  .card-wip .day-number {
    color: #e74c3c;
  }

  .status-badge {
    display: inline-block;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    margin-right: 0.4em;
    vertical-align: middle;
  }

  .badge-wip { background: #c0392b; }
  .badge-incomplete { background: #555; }
  .badge-fail { background: #8b2020; }

  .card-incomplete {
    border-color: var(--color-border);
    opacity: 0.6;
  }

  .card-incomplete:hover {
    border-color: var(--color-text-muted);
    opacity: 0.8;
  }

  .card-incomplete .day-number {
    color: var(--color-text-muted);
  }

  .card-fail {
    border-color: #6b1a1a;
  }

  .card-fail:hover {
    border-color: #8b2020;
  }

  .card-fail .day-number {
    color: #8b2020;
  }

  .card-template {
    opacity: 0.5;
    border-color: var(--color-border);
  }

  .card-template:hover {
    opacity: 0.7;
    border-color: var(--color-text-muted);
  }

  .card-template .day-number {
    color: var(--color-text-muted);
  }

  .card-template .badge {
    background: var(--color-bg-control, #1a1a28);
    color: var(--color-text-muted);
  }
</style>
