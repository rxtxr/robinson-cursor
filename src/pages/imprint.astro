---
import Base from '../layouts/Base.astro';

// Obfuscate imprint data at build time.
// Encode to UTF-8 bytes, XOR each byte, then base64 the result.
// Data is only decoded after a user click.

const imprintData = [
  { type: 'h1', text: 'Imprint' },
  { type: 'h2', text: 'Information according to \u00A7 5 TMG' },
  { type: 'p',  text: 'Marius Bruns' },
  { type: 'p',  text: 'Piependamm 8' },
  { type: 'p',  text: '28279 Bremen, Germany' },
  { type: 'h2', text: 'Contact' },
  { type: 'p',  text: 'mareisen@pm.me' },
  { type: 'h2', text: 'Responsible for content according to \u00A7 55 Abs. 2 RStV' },
  { type: 'p',  text: 'Marius Bruns' },
  { type: 'p',  text: 'Piependamm 8, 28279 Bremen' },
];

const key = 'rc365vibe';

function xorEncodeBytes(str, k) {
  const textBytes = Buffer.from(str, 'utf-8');
  const keyBytes = Buffer.from(k, 'utf-8');
  const result = Buffer.alloc(textBytes.length);
  for (let i = 0; i < textBytes.length; i++) {
    result[i] = textBytes[i] ^ keyBytes[i % keyBytes.length];
  }
  return result.toString('base64');
}

const encoded = Buffer.from(
  JSON.stringify(imprintData.map(d => ({ t: d.type, c: xorEncodeBytes(d.text, key) })))
).toString('base64');

const keyParts = [key.slice(0, 3), key.slice(3, 6), key.slice(6)];
---

<Base title="Imprint — robinson-cursor.com" description="" noindex={true}>
  <article class="imprint-page" id="imprint">
    <p class="gate-text">Legal information as required by German law.</p>
    <button class="reveal-btn" id="reveal" type="button">show imprint</button>
    <div class="imprint-content" id="content" hidden></div>
    <noscript><p>This page requires JavaScript.</p></noscript>
  </article>
</Base>

<script define:vars={{ encoded, keyParts }}>
  const btn = document.getElementById('reveal');
  const content = document.getElementById('content');

  function b64ToBytes(b64) {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  }

  function xorDecodeBytes(b64, k) {
    const data = b64ToBytes(b64);
    const keyBytes = new TextEncoder().encode(k);
    const result = new Uint8Array(data.length);
    for (let i = 0; i < data.length; i++) {
      result[i] = data[i] ^ keyBytes[i % keyBytes.length];
    }
    return new TextDecoder().decode(result);
  }

  btn.addEventListener('click', () => {
    const k = keyParts[0] + keyParts[1] + keyParts[2];
    const raw = JSON.parse(new TextDecoder().decode(b64ToBytes(encoded)));
    const frag = document.createDocumentFragment();

    for (const item of raw) {
      const el = document.createElement(item.t);
      el.textContent = xorDecodeBytes(item.c, k);
      frag.appendChild(el);
    }

    content.replaceChildren(frag);
    content.hidden = false;
    btn.remove();
    document.querySelector('.gate-text')?.remove();
  }, { once: true });
</script>

<style>
  .imprint-page {
    max-width: 580px;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .gate-text {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .reveal-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .reveal-btn:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
  }

  .imprint-content :global(h1) {
    margin-bottom: var(--space-lg);
  }

  .imprint-content :global(h2) {
    font-size: 1rem;
    color: var(--color-accent);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .imprint-content :global(p) {
    color: var(--color-text-muted);
  }
</style>
