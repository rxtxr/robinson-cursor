---
import Base from '../layouts/Base.astro';

// Obfuscate imprint data at build time: XOR with a key, then base64-encode.
// The key is split across JS so it never appears as a single readable string.
// Data is only decoded after a user click — bots that execute JS but don't
// simulate clicks will never see the content.

const imprintData = [
  { type: 'h1', text: 'Imprint' },
  { type: 'h2', text: 'Information according to § 5 TMG' },
  { type: 'p',  text: 'Marius Bruns' },
  { type: 'p',  text: 'Piependamm 8' },
  { type: 'p',  text: '28279 Bremen, Germany' },
  { type: 'h2', text: 'Contact' },
  { type: 'p',  text: 'mareisen@pm.me' },
  { type: 'h2', text: 'Responsible for content according to § 55 Abs. 2 RStV' },
  { type: 'p',  text: 'Marius Bruns' },
  { type: 'p',  text: 'Piependamm 8, 28279 Bremen' },
];

const key = 'rc365vibe';
function xorEncode(str, k) {
  return Array.from(str).map((c, i) =>
    String.fromCharCode(c.charCodeAt(0) ^ k.charCodeAt(i % k.length))
  ).join('');
}

const encoded = Buffer.from(
  JSON.stringify(imprintData.map(d => ({ t: d.type, c: xorEncode(d.text, key) })))
).toString('base64');

// Split the key into parts that get assembled at runtime
const keyParts = [key.slice(0, 3), key.slice(3, 6), key.slice(6)];
---

<Base title="Imprint — robinson-cursor.com" description="" noindex={true}>
  <article class="imprint-page" id="imprint">
    <h1>imprint</h1>
    <p class="gate-text">Legal information as required by German law.</p>
    <button class="reveal-btn" id="reveal" type="button">show imprint</button>
    <div class="imprint-content" id="content" hidden></div>
    <noscript><p>This page requires JavaScript.</p></noscript>
  </article>
</Base>

<script define:vars={{ encoded, keyParts }}>
  const btn = document.getElementById('reveal');
  const content = document.getElementById('content');

  btn.addEventListener('click', () => {
    // Assemble key from parts
    const k = keyParts[0] + keyParts[1] + keyParts[2];

    // Decode
    const raw = JSON.parse(atob(encoded));
    const frag = document.createDocumentFragment();

    for (const item of raw) {
      const decoded = Array.from(item.c).map((c, i) =>
        String.fromCharCode(c.charCodeAt(0) ^ k.charCodeAt(i % k.length))
      ).join('');

      const el = document.createElement(item.t);
      el.textContent = decoded;
      frag.appendChild(el);
    }

    content.replaceChildren(frag);
    content.hidden = false;
    btn.remove();
    document.querySelector('.gate-text')?.remove();
  }, { once: true });
</script>

<style>
  .imprint-page {
    max-width: 580px;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .gate-text {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .reveal-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .reveal-btn:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
  }

  .imprint-content :global(h1) {
    margin-bottom: var(--space-lg);
  }

  .imprint-content :global(h2) {
    font-size: 1rem;
    color: var(--color-accent);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .imprint-content :global(p) {
    color: var(--color-text-muted);
  }
</style>
