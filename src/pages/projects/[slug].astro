---
import Base from '../../layouts/Base.astro';
import { getAllProjects } from '../../lib/projects.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const dayNum = String(project.day).padStart(3, '0');

// Check for thumbnail
const thumbFiles = import.meta.glob('/projects/*/thumb.png', { eager: true, query: '?url', import: 'default' });
const thumbKey = `/projects/${project.slug}/thumb.png`;
const thumbUrl = thumbFiles[thumbKey] || null;

// Load README if it exists
const readmeFiles = import.meta.glob('/projects/*/README.md', { query: '?raw', import: 'default', eager: true });
const readmeKey = `/projects/${project.slug}/README.md`;
const readmeRaw = readmeFiles[readmeKey];
const readmeContent = readmeRaw ? marked.parse(readmeRaw) : null;

// Get all projects for prev/next navigation
const allProjects = await getAllProjects();
const sorted = allProjects
  .filter((p) => p.status !== 'template')
  .sort((a, b) => a.day - b.day);
const currentIndex = sorted.findIndex((p) => p.slug === project.slug);
const prevProject = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextProject = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<Base title={`#${dayNum} ${project.title} — robinson-cursor.com`} description={project.description} ogImage={thumbUrl || ''}>
  <article class="project-detail" data-slug={project.slug} style={project.accentColor ? `--color-accent: ${project.accentColor}` : ''}>
    <nav class="project-nav project-nav-top" aria-label="Project navigation">
      <a href="/" class="nav-back" aria-label="Back to all projects">&larr; all projects</a>
      <div class="nav-prevnext">
        {prevProject && (
          <a href={`/projects/${prevProject.slug}`} class="nav-prev" aria-label={`Previous: ${prevProject.title}`}>&larr; #{String(prevProject.day).padStart(3, '0')}</a>
        )}
        {nextProject && (
          <a href={`/projects/${nextProject.slug}`} class="nav-next" aria-label={`Next: ${nextProject.title}`}>#{String(nextProject.day).padStart(3, '0')} &rarr;</a>
        )}
      </div>
    </nav>
    <header class="project-header">
      <div class="meta-line">
        <span class="day-number">#{dayNum}</span>
        <time class="date" datetime={project.date}>{project.date}</time>
        <span class:list={['status', `status-${project.status}`]}>{project.statusLabel || project.status}</span>
      </div>
      <h1>{project.title}</h1>
      {project.description?.toLowerCase().includes('photosensitivity') && (
        <div class="epilepsy-warning" role="alert">
          Photosensitivity Warning: This project contains rapidly changing high-contrast patterns
          and animations that may cause discomfort or trigger seizures in people with photosensitive epilepsy.
        </div>
      )}
      <p class="description">{project.description}</p>
      <a href={`/embed/${project.slug}/index.html`} target="_blank" rel="noopener" class="run-btn" id="run-btn" aria-label={`Run ${project.title} (opens in new tab)`}><span class="run-prompt" aria-hidden="true">&gt; </span>run<span class="run-cursor" aria-hidden="true">_</span></a>
    </header>

    {thumbUrl && (
      <a href={`/embed/${project.slug}/index.html`} target="_blank" rel="noopener" class="project-thumb" aria-label={`Run ${project.title}`}>
        <img src={thumbUrl} alt={`Screenshot of ${project.title}`} loading="lazy" />
      </a>
    )}

    <div class="project-meta">
      {project.stack && project.stack.length > 0 && (
        <div class="meta-group">
          <h3>stack</h3>
          <div class="tag-list">
            {project.stack.map((s) => <span class="badge">{s}</span>)}
          </div>
        </div>
      )}
      {project.tags && project.tags.length > 0 && (
        <div class="meta-group">
          <h3>tags</h3>
          <div class="tag-list">
            {project.tags.map((t) => <span class="badge">{t}</span>)}
          </div>
        </div>
      )}
    </div>


    {readmeContent && (
      <section class="project-readme">
        <h2>documentation</h2>
        <div class="readme-content" set:html={readmeContent} />
      </section>
    )}

    {project.license_notes && (
      <section class="license-notes">
        <h3>licenses</h3>
        <p>{project.license_notes}</p>
      </section>
    )}

    {project.github && (
      <p class="github-link">
        <a href={project.github} target="_blank" rel="noopener" aria-label={`Source code for ${project.title} on GitHub (opens in new tab)`}>source on github</a>
      </p>
    )}

    <nav class="project-nav" aria-label="Project navigation">
      <a href="/" class="nav-back" aria-label="Back to all projects">&larr; all projects</a>
      <div class="nav-prevnext">
        {prevProject && (
          <a href={`/projects/${prevProject.slug}`} class="nav-prev" aria-label={`Previous: ${prevProject.title}`}>&larr; #{String(prevProject.day).padStart(3, '0')}</a>
        )}
        {nextProject && (
          <a href={`/projects/${nextProject.slug}`} class="nav-next" aria-label={`Next: ${nextProject.title}`}>#{String(nextProject.day).padStart(3, '0')} &rarr;</a>
        )}
      </div>
    </nav>
  </article>
</Base>

<script>
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const tag = document.activeElement?.tagName;
    if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA' || tag === 'A' || tag === 'BUTTON') return;
    document.getElementById('run-btn')?.click();
  });

  // === SELF DESTRUCT for day-015 — intercept Run button ===
  (() => {
    const article = document.querySelector('[data-slug="day-015-self-destruct"]');
    if (!article) return;

    const runBtn = document.getElementById('run-btn');
    if (!runBtn) return;

    runBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (document.body.classList.contains('self-destructing')) return;
      document.body.classList.add('self-destructing');
      runSelfDestruct();
    });

    function runSelfDestruct() {
      // Inject CSS
      const style = document.createElement('style');
      style.textContent = `
        .sd-noise{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:0;mix-blend-mode:overlay}
        .sd-noise.active{opacity:1}
        .sd-scanlines{position:fixed;inset:0;z-index:9998;pointer-events:none;opacity:0;
          background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.15) 2px,rgba(0,0,0,.15) 4px);transition:opacity .5s}
        .sd-scanlines.active{opacity:1}
        .sd-blackout{position:fixed;inset:0;background:var(--color-bg,#0a0a0f);z-index:10000;opacity:0;pointer-events:none;
          display:flex;align-items:center;justify-content:center;flex-direction:column;transition:opacity .5s}
        .sd-blackout.active{opacity:1;pointer-events:all}
        .sd-blackout-text{font-family:var(--font-mono,monospace);color:#ff3366;font-size:clamp(1rem,3vw,1.5rem);opacity:0;animation:sdFI 1s .5s forwards}
        .sd-redirect-hint{font-family:var(--font-mono,monospace);color:var(--color-text-muted,#6a6a7a);font-size:.8rem;opacity:0;margin-top:1.5rem;animation:sdFI 1s 1.5s forwards}
        @keyframes sdFI{0%{opacity:0;transform:translateY(10px);filter:blur(4px)}100%{opacity:1;transform:translateY(0);filter:blur(0)}}
        @keyframes sdCh{0%{text-shadow:-2px 0 #ff0040,2px 0 #00ffcc}25%{text-shadow:2px -1px #ff0040,-2px 1px #6644ff;filter:brightness(1.3)}50%{text-shadow:-1px 2px #00ffcc,1px -2px #ff0040;filter:hue-rotate(20deg)}75%{text-shadow:3px 0 #6644ff,-3px 0 #ff0040;filter:brightness(.7)}100%{text-shadow:-2px 0 #ff0040,2px 0 #00ffcc}}
        .sd-chromatic{animation:sdCh var(--sd-speed,.15s) steps(2) infinite}
        @keyframes sdFl{0%{opacity:1}10%{opacity:0}12%{opacity:1}40%{opacity:1}42%{opacity:.3}44%{opacity:1}80%{opacity:1}82%{opacity:0}85%{opacity:.6}87%{opacity:1}}
        .sd-flicker{animation:sdFl var(--sd-speed,.08s) steps(1) infinite}
        @keyframes sdDeg{0%{filter:saturate(1) contrast(1) brightness(1)}30%{filter:saturate(3) contrast(1.5) brightness(1.2)}60%{filter:saturate(.3) contrast(2) brightness(.6) hue-rotate(90deg)}100%{filter:saturate(0) contrast(3) brightness(.2) hue-rotate(180deg)}}
        .sd-degrade{animation:sdDeg var(--sd-speed,.5s) linear infinite alternate}
        @keyframes sdDis{0%{opacity:1;transform:scale(1);filter:blur(0)}50%{opacity:.5;transform:scale(1.05);filter:blur(2px)}100%{opacity:0;transform:scale(.95) translateY(10px);filter:blur(8px)}}
        .sd-dissolve{animation:sdDis .3s steps(4) forwards}
        @keyframes sdTear{0%{clip-path:inset(0);transform:translateX(0)}20%{clip-path:inset(var(--tear-y1,20%) 0 var(--tear-y2,60%) 0);transform:translateX(var(--tear-x,10px))}40%{clip-path:inset(var(--tear-y3,50%) 0 var(--tear-y4,30%) 0);transform:translateX(calc(var(--tear-x,10px)*-.7))}60%{clip-path:inset(0);transform:translateX(0)}80%{clip-path:inset(var(--tear-y5,70%) 0 var(--tear-y6,10%) 0);transform:translateX(var(--tear-x,10px))}100%{clip-path:inset(0);transform:translateX(0)}}
        .sd-tear{animation:sdTear var(--sd-speed,.1s) steps(1) infinite}
        .self-destructing{pointer-events:none}.self-destructing .sd-blackout{pointer-events:all}
      `;
      document.head.appendChild(style);

      // Inject overlays
      const noise = document.createElement('canvas');
      noise.className = 'sd-noise';
      const scanlines = document.createElement('div');
      scanlines.className = 'sd-scanlines';
      const blackout = document.createElement('div');
      blackout.className = 'sd-blackout';
      blackout.innerHTML = '<div class="sd-blackout-text">SIGNAL LOST</div><div class="sd-redirect-hint">recovering...</div>';
      document.body.appendChild(noise);
      document.body.appendChild(scanlines);
      document.body.appendChild(blackout);

      // Noise canvas
      const nCtx = noise.getContext('2d');
      noise.width = Math.ceil(window.innerWidth / 3);
      noise.height = Math.ceil(window.innerHeight / 3);
      noise.style.cssText = 'width:100%;height:100%';
      let noiseIntensity = 0;
      let noiseRunning = true;
      function drawNoise() {
        if (!noiseRunning) return;
        const w = noise.width, h = noise.height;
        const img = nCtx.createImageData(w, h);
        const d = img.data;
        for (let i = 0; i < d.length; i += 4) {
          const v = Math.random() * 255 * noiseIntensity;
          d[i]=v; d[i+1]=v; d[i+2]=v; d[i+3]=255*noiseIntensity;
        }
        nCtx.putImageData(img, 0, 0);
        requestAnimationFrame(drawNoise);
      }

      const rand=(a,b)=>Math.random()*(b-a)+a;
      const randInt=(a,b)=>Math.floor(rand(a,b));
      const pick=a=>a[randInt(0,a.length)];

      // Text corruption
      const MIMIC={'a':'àáâãäåāăαа','e':'èéêëēĕėεеё','i':'ìíîïīĭιіі','o':'òóôõöøōŏοо','u':'ùúûüūŭůυу','s':'śŝşšƨ§ʂ','c':'çćĉċčсↄ','n':'ñńņňŉηп','r':'ŕŗřгя','t':'ţťŧτт','d':'ďđðδд','l':'ĺļľŀłℓ','A':'ÀÁÂÃÄÅĀΑА','E':'ÈÉÊËĒΕЕ','S':'ŚŜŞŠƧ§','O':'ÒÓÔÕÖØŌΟ','C':'ÇĆĈČС','D':'ĎĐÐΔД'};
      const MOJIBAKE='ÃƒÂ¤Ã¶Ã¼Ã„Ã–ÃœÃŸÂ©Â®â€"â€˜â€™Ã©Ã¨Ãªï¿½Â¿Â¡'.split('');
      const BLOCKS='░▒▓█▄▀▌▐─│┌┐└┘├┤┬┴┼╔╗╚╝║═'.split('');
      const ZALGO_UP='\u0300\u0301\u0302\u0303\u0304\u0305\u0306\u0307\u0308\u030A\u030B\u030C\u030D\u030E\u030F\u0310\u0311\u0312\u0313\u0314\u033D\u033E\u033F\u0340\u0341\u0342\u0343\u0344\u0346\u034A\u034B\u034C'.split('');
      const ZALGO_DN='\u0316\u0317\u0318\u0319\u031C\u031D\u031E\u031F\u0320\u0321\u0322\u0323\u0324\u0325\u0326\u0327\u0328\u0329\u032A\u032B\u032C\u032D\u032E\u032F\u0330\u0331\u0332\u0333\u0339\u033A\u033B\u033C\u0345\u0347\u0348\u0349'.split('');
      const ZALGO_MID='\u0315\u031A\u0334\u0335\u0336\u0337\u0338'.split('');
      const ERRS=['NULL','0xDEAD','???','###','ERR','NaN','0xFF','SEGFAULT','<!>','[CORRUPT]','\\x00','undefined','FATAL','>>>','<<<','■■■'];
      const origTexts=new Map();
      function collectText(el){const nodes=[];const w=document.createTreeWalker(el,NodeFilter.SHOW_TEXT);let n;while(n=w.nextNode()){if(n.textContent.trim()){nodes.push(n);if(!origTexts.has(n))origTexts.set(n,n.textContent)}}return nodes}
      function corruptChar(c,intensity){if(c===' '||c==='\n')return c;const r=Math.random();if(intensity<.3){if(r<.15&&MIMIC[c]){const p=MIMIC[c];return p[Math.floor(Math.random()*p.length)]}return c}if(intensity<.6){if(r<.1)return pick(MOJIBAKE);if(r<.18)return pick(BLOCKS);if(r<.28){let z=c;for(let i=0;i<randInt(1,3);i++)z+=pick([...ZALGO_UP,...ZALGO_DN]);return z}if(r<.35&&MIMIC[c]){const p=MIMIC[c];return p[Math.floor(Math.random()*p.length)]}return c}if(r<.15)return pick(MOJIBAKE);if(r<.25)return pick(BLOCKS);if(r<.45){let z=c;for(let i=0;i<randInt(2,8);i++)z+=pick([...ZALGO_UP,...ZALGO_DN,...ZALGO_MID]);return z}if(r<.55)return String.fromCharCode(randInt(0x2500,0x25FF));if(r<.6)return String.fromCharCode(randInt(0x0400,0x04FF));return c}
      function corruptText(text,intensity){if(intensity>.4&&Math.random()<intensity*.15)return text.split(/(\s+)/).map(w=>{if(w.trim()&&Math.random()<intensity*.3)return pick(ERRS);return w.split('').map(c=>corruptChar(c,intensity)).join('')}).join('');return text.split('').map(c=>corruptChar(c,intensity)).join('')}
      let corruptIvs=[];
      function startCorruption(intensity,speed){targets.forEach(el=>{const nodes=collectText(el);if(!nodes.length)return;corruptIvs.push(setInterval(()=>{nodes.forEach(n=>{const o=origTexts.get(n);if(o)n.textContent=corruptText(o,intensity)})},speed))})}
      function stopCorruption(){corruptIvs.forEach(clearInterval);corruptIvs=[]}

      // Targets: all visible content on the detail page
      const targets=[...document.querySelectorAll('.project-header, .project-meta, .project-readme, .license-notes, .github-link, .project-nav, header, footer, .project-thumb')].filter(Boolean);
      const wrapper = document.querySelector('main')?.parentElement || document.body;

      // START
      noiseIntensity=0.05; noise.classList.add('active');
      scanlines.classList.add('active'); scanlines.style.opacity='0.3';
      drawNoise();

      // Phase 1 (0-2s)
      const p1=setInterval(()=>{const t=pick(targets);if(!t)return;t.classList.add('sd-chromatic');t.style.setProperty('--sd-speed',`${rand(.1,.3)}s`);setTimeout(()=>t.classList.remove('sd-chromatic'),rand(100,400))},200);
      let wf;(function sw(){wrapper.style.transform=`skewX(${rand(-.5,.5)}deg)`;wf=requestAnimationFrame(sw)})();
      startCorruption(0.15,300);

      // Phase 2 (2-5s)
      setTimeout(()=>{
        clearInterval(p1);cancelAnimationFrame(wf);
        noiseIntensity=.15;scanlines.style.opacity='.6';
        stopCorruption();startCorruption(.4,150);
        targets.forEach(t=>{if(Math.random()>.4){t.classList.add('sd-chromatic');t.style.setProperty('--sd-speed',`${rand(.05,.15)}s`)}if(Math.random()>.6){t.classList.add('sd-tear');t.style.setProperty('--sd-speed',`${rand(.05,.2)}s`);t.style.setProperty('--tear-x',`${randInt(5,30)}px`);['tear-y1','tear-y2','tear-y3','tear-y4','tear-y5','tear-y6'].forEach(v=>t.style.setProperty(`--${v}`,`${randInt(10,70)}%`))}});
        const w2=setInterval(()=>{wrapper.style.transform=`skewX(${rand(-3,3)}deg) scaleY(${rand(.98,1.03)})`;wrapper.style.filter=`hue-rotate(${randInt(-30,30)}deg) brightness(${rand(.7,1.4)})`},80);
        const fl2=setInterval(()=>{const t=pick(targets);if(!t)return;t.classList.add('sd-flicker');t.style.setProperty('--sd-speed',`${rand(.04,.1)}s`);setTimeout(()=>t.classList.remove('sd-flicker'),rand(200,800))},150);

        // Phase 3 (5-8s)
        setTimeout(()=>{
          clearInterval(w2);clearInterval(fl2);
          noiseIntensity=.4;scanlines.style.opacity='1';
          stopCorruption();startCorruption(.8,60);
          targets.forEach(t=>{t.classList.add('sd-degrade','sd-chromatic');t.style.setProperty('--sd-speed',`${rand(.03,.08)}s`)});
          const vi=setInterval(()=>{wrapper.style.transform=`skewX(${rand(-8,8)}deg) scaleY(${rand(.92,1.1)}) scaleX(${rand(.97,1.04)}) translate(${randInt(-15,15)}px,${randInt(-5,5)}px)`;wrapper.style.filter=`hue-rotate(${randInt(-90,90)}deg) brightness(${rand(.3,2)}) contrast(${rand(.5,3)}) saturate(${rand(0,5)})`},40);
          const sh=[...targets].sort(()=>Math.random()-.5);let di=0;
          const dI=setInterval(()=>{if(di<sh.length){sh[di].classList.add('sd-dissolve');di++}},200);

          // Phase 4: death
          setTimeout(()=>{
            clearInterval(vi);clearInterval(dI);stopCorruption();
            noiseIntensity=.8;let fc=0;
            const fl=setInterval(()=>{
              if(fc>6){clearInterval(fl);noiseRunning=false;wrapper.style.display='none';scanlines.classList.remove('active');blackout.classList.add('active');
                setTimeout(()=>{window.location.href='/embed/day-015-self-destruct/index.html'},2500);return}
              wrapper.style.filter=fc%2===0?'brightness(5) contrast(0) saturate(0)':'brightness(0) contrast(0)';fc++},100);
          },3000);
        },3000);
      },2000);
    }
  })();
</script>

<style>
  .project-detail {
    max-width: 900px;
  }

  .project-header {
    margin-bottom: var(--space-lg);
  }

  .meta-line {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: var(--space-sm);
  }

  .day-number {
    color: var(--color-accent);
    font-weight: 700;
  }

  .date {
    color: var(--color-text-muted);
  }

  .status {
    padding: 2px 8px;
    border-radius: var(--radius);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-complete { background: #0a2a1a; color: #00d4aa; }
  .status-wip { background: #2a2a0a; color: #d4aa00; }
  .status-incomplete { background: #1a1a1a; color: #888; }
  .status-fail { background: #2a0a0a; color: #d44a4a; }
  .status-template { background: #1a1a2a; color: #6a6a7a; }

  .epilepsy-warning {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: rgba(204, 136, 0, 0.1);
    border: 1px solid rgba(204, 136, 0, 0.3);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: #cc8800;
    line-height: 1.6;
  }

  .description {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    font-size: 0.95rem;
  }

  .run-btn {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: var(--radius);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: background 0.2s, transform 0.1s;
  }

  .run-btn:hover {
    background: var(--color-text-heading);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .run-prompt {
    opacity: 0.6;
  }

  .run-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .project-thumb {
    display: block;
    margin-bottom: var(--space-lg);
    cursor: pointer;
  }

  .project-thumb img {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .project-meta {
    display: flex;
    gap: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .meta-group h3 {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: lowercase;
    margin-bottom: var(--space-xs);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-readme {
    margin: var(--space-lg) 0;
  }

  .project-readme h2 {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .readme-content {
    line-height: 1.8;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .readme-content :global(h1) {
    font-size: 1.3rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .readme-content :global(h2) {
    font-size: 1.1rem;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .readme-content :global(h3) {
    font-size: 0.95rem;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .readme-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .readme-content :global(pre) {
    background: var(--color-bg-card);
