---
import Base from '../../layouts/Base.astro';
import { getAllProjects } from '../../lib/projects.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const dayNum = String(project.day).padStart(3, '0');

// Check for thumbnail
const thumbFiles = import.meta.glob('/projects/*/thumb.png', { eager: true, query: '?url', import: 'default' });
const thumbKey = `/projects/${project.slug}/thumb.png`;
const thumbUrl = thumbFiles[thumbKey] || null;

// Load README if it exists
const readmeFiles = import.meta.glob('/projects/*/README.md', { query: '?raw', import: 'default', eager: true });
const readmeKey = `/projects/${project.slug}/README.md`;
const readmeRaw = readmeFiles[readmeKey];
const readmeContent = readmeRaw ? marked.parse(readmeRaw) : null;

// Get all projects for prev/next navigation
const allProjects = await getAllProjects();
const sorted = allProjects
  .filter((p) => p.status !== 'template')
  .sort((a, b) => a.day - b.day);
const currentIndex = sorted.findIndex((p) => p.slug === project.slug);
const prevProject = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextProject = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<Base title={`#${dayNum} ${project.title} — robinson-cursor.com`} description={project.description} ogImage={thumbUrl || ''}>
  <article class="project-detail">
    <header class="project-header">
      <div class="meta-line">
        <span class="day-number">#{dayNum}</span>
        <time datetime={project.date}>{project.date}</time>
        <span class:list={['status', `status-${project.status}`]}>{project.status}</span>
      </div>
      <h1>{project.title}</h1>
      {project.description?.toLowerCase().includes('photosensitivity') && (
        <div class="epilepsy-warning" role="alert">
          Photosensitivity Warning: This project contains rapidly changing high-contrast patterns
          and animations that may cause discomfort or trigger seizures in people with photosensitive epilepsy.
        </div>
      )}
      <p class="description">{project.description}</p>
      <a href={`/embed/${project.slug}/index.html`} target="_blank" rel="noopener" class="run-btn" aria-label={`Run ${project.title} (opens in new tab)`}>run</a>
    </header>

    {thumbUrl && (
      <div class="project-thumb">
        <img src={thumbUrl} alt={`Screenshot of ${project.title}`} loading="lazy" />
      </div>
    )}

    <div class="project-meta">
      {project.stack && project.stack.length > 0 && (
        <div class="meta-group">
          <h3>stack</h3>
          <div class="tag-list">
            {project.stack.map((s) => <span class="badge">{s}</span>)}
          </div>
        </div>
      )}
      {project.tags && project.tags.length > 0 && (
        <div class="meta-group">
          <h3>tags</h3>
          <div class="tag-list">
            {project.tags.map((t) => <span class="badge">{t}</span>)}
          </div>
        </div>
      )}
    </div>


    {readmeContent && (
      <section class="project-readme">
        <h2>documentation</h2>
        <div class="readme-content" set:html={readmeContent} />
      </section>
    )}

    {project.license_notes && (
      <section class="license-notes">
        <h3>licenses</h3>
        <p>{project.license_notes}</p>
      </section>
    )}

    {project.github && (
      <p class="github-link">
        <a href={project.github} target="_blank" rel="noopener" aria-label={`Source code for ${project.title} on GitHub (opens in new tab)`}>source on github</a>
      </p>
    )}

    <nav class="project-nav" aria-label="Project navigation">
      <a href="/" class="nav-back" aria-label="Back to all projects">&larr; all projects</a>
      <div class="nav-prevnext">
        {prevProject && (
          <a href={`/projects/${prevProject.slug}`} class="nav-prev" aria-label={`Previous: ${prevProject.title}`}>&larr; #{String(prevProject.day).padStart(3, '0')}</a>
        )}
        {nextProject && (
          <a href={`/projects/${nextProject.slug}`} class="nav-next" aria-label={`Next: ${nextProject.title}`}>#{String(nextProject.day).padStart(3, '0')} &rarr;</a>
        )}
      </div>
    </nav>
  </article>
</Base>

<style>
  .project-detail {
    max-width: 900px;
  }

  .project-header {
    margin-bottom: var(--space-lg);
  }

  .meta-line {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: var(--space-sm);
  }

  .day-number {
    color: var(--color-accent);
    font-weight: 700;
  }

  .date {
    color: var(--color-text-muted);
  }

  .status {
    padding: 2px 8px;
    border-radius: var(--radius);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-complete { background: #0a2a1a; color: #00d4aa; }
  .status-wip { background: #2a2a0a; color: #d4aa00; }
  .status-template { background: #1a1a2a; color: #6a6a7a; }

  .epilepsy-warning {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: rgba(204, 136, 0, 0.1);
    border: 1px solid rgba(204, 136, 0, 0.3);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: #cc8800;
    line-height: 1.6;
  }

  .description {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    font-size: 0.95rem;
  }

  .run-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: var(--radius);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: background 0.2s, transform 0.1s;
  }

  .run-btn:hover {
    background: var(--color-text-heading);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .project-thumb {
    margin-bottom: var(--space-lg);
  }

  .project-thumb img {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .project-meta {
    display: flex;
    gap: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .meta-group h3 {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: lowercase;
    margin-bottom: var(--space-xs);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-readme {
    margin: var(--space-lg) 0;
  }

  .project-readme h2 {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .readme-content {
    line-height: 1.8;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .readme-content :global(h1) {
    font-size: 1.3rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .readme-content :global(h2) {
    font-size: 1.1rem;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .readme-content :global(h3) {
    font-size: 0.95rem;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .readme-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .readme-content :global(pre) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    overflow-x: auto;
    margin: var(--space-md) 0;
    font-size: 0.85rem;
  }

  .readme-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .readme-content :global(:not(pre) > code) {
    background: var(--color-bg-card);
    padding: 2px 6px;
    border-radius: var(--radius);
    color: var(--color-accent);
  }

  .readme-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: 0.85rem;
  }

  .readme-content :global(th),
  .readme-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .readme-content :global(th) {
    background: var(--color-bg-card);
    color: var(--color-text-heading);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: lowercase;
  }

  .readme-content :global(td) {
    color: var(--color-text-muted);
  }

  .readme-content :global(ul),
  .readme-content :global(ol) {
    margin: var(--space-sm) 0 var(--space-md) var(--space-lg);
  }

  .readme-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .license-notes {
    margin: var(--space-lg) 0;
    padding: var(--space-md);
    background: var(--color-bg-card);
    border-radius: var(--radius);
    font-size: 0.85rem;
  }

  .license-notes h3 {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .github-link {
    margin: var(--space-md) 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .nav-prevnext {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-back,
  .nav-prev,
  .nav-next {
    color: var(--color-text-muted);
  }

  .nav-back:hover,
  .nav-prev:hover,
  .nav-next:hover {
    color: var(--color-accent);
  }
</style>
