---
import Base from '../layouts/Base.astro';

const key = 'rc365vibe';

function xorEncodeBytes(str: string, k: string) {
  const textBytes = Buffer.from(str, 'utf-8');
  const keyBytes = Buffer.from(k, 'utf-8');
  const result = Buffer.alloc(textBytes.length);
  for (let i = 0; i < textBytes.length; i++) {
    result[i] = textBytes[i] ^ keyBytes[i % keyBytes.length];
  }
  return result.toString('base64');
}

const emailEncoded = xorEncodeBytes('mareisen@pm.me', key);
const keyParts = [key.slice(0, 3), key.slice(3, 6), key.slice(6)];
---

<Base title="Bug Bounty — robinson-cursor.com" description="Find bugs, earn beer.">
  <article class="bounty-page">
    <h1>Bug Bounty</h1>
    <p class="tagline">Find bugs, earn beer.</p>

    <p>Found something broken? Email me at <button class="email-btn" id="showEmail" type="button">show address</button><span id="emailSlot"></span> with what happened, where, and on which browser.</p>

    <p><strong>Reward:</strong> one beer per reproducible bug. Severe bugs may earn more. Pick up your beer <strong>in person in Bremen</strong> — no cash equivalent, no shipping.</p>

    <p class="legal">I decide what counts. Duplicates don't. No legal recourse.</p>
  </article>
</Base>

<script define:vars={{ emailEncoded, keyParts }}>
  const btn = document.getElementById('showEmail');
  const slot = document.getElementById('emailSlot');

  function b64ToBytes(b64) {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  }

  function xorDecode(b64, k) {
    const data = b64ToBytes(b64);
    const keyBytes = new TextEncoder().encode(k);
    const result = new Uint8Array(data.length);
    for (let i = 0; i < data.length; i++) {
      result[i] = data[i] ^ keyBytes[i % keyBytes.length];
    }
    return new TextDecoder().decode(result);
  }

  btn.addEventListener('click', () => {
    const k = keyParts[0] + keyParts[1] + keyParts[2];
    const email = xorDecode(emailEncoded, k);
    const link = document.createElement('a');
    link.href = 'mailto:' + email + '?subject=Bug%20Report%20%E2%80%94%20robinson-cursor.com';
    link.textContent = email;
    btn.replaceWith(link);
  }, { once: true });
</script>

<style>
  .bounty-page {
    max-width: 580px;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .tagline {
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: var(--space-lg);
  }

  p { color: var(--color-text-muted); }
  strong { color: var(--color-text); }

  .legal {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
  }

  .email-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.1em 0.5em;
    background: var(--color-bg-card);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .email-btn:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
  }
</style>
